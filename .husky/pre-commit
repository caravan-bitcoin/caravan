echo "🚀 Pre-commit checks (from $(pwd))..."

# Find the git root directory (works from anywhere in monorepo)
GIT_ROOT=$(git rev-parse --show-toplevel)
echo "📁 Git root: $GIT_ROOT"

# 1. Check Node.js version (get it from package.json engines)
echo "1️⃣ Checking Node.js version..."
CURRENT_NODE=$(node --version)

# Find package.json with engines field
ENGINES_FILE="$GIT_ROOT/package.json"

if [ -n "$ENGINES_FILE" ]; then
    echo "   📋 Using engines from: $ENGINES_FILE"

    # Extract Node version requirement from engines field
    NODE_REQUIREMENT=$(node -e "
        try {
            const pkg = require('$ENGINES_FILE');
            if (pkg.engines && pkg.engines.node) {
                console.log(pkg.engines.node);
            }
        } catch(e) {
            console.log('⚠️  package.json with no engines field found')
            process.exit(1);
        }
    ")

    if [ $? -eq 0 ] && [ -n "$NODE_REQUIREMENT" ]; then
        echo "   📝 Required Node.js: $NODE_REQUIREMENT"
        echo "   💻 Current Node.js: $CURRENT_NODE"

        # Extract major version for basic check
        # We are using shell-based version checking

        CURRENT_MAJOR=$(echo "$CURRENT_NODE" | sed 's/v\([0-9]*\)\..*/\1/')
        REQUIRED_MAJOR=$(echo "$NODE_REQUIREMENT" | sed 's/[^0-9]*\([0-9]*\).*/\1/')

        if [ "$CURRENT_MAJOR" -lt "$REQUIRED_MAJOR" ]; then
            echo ""
            echo "❌ Node.js version too old!"
            echo "   Required: Node >= $REQUIRED_MAJOR.x (from: $NODE_REQUIREMENT)"
            echo "   Current:  $CURRENT_NODE"
            echo ""
            echo "   To fix this:"
            echo "   1. Run: nvm use $REQUIRED_MAJOR"
            echo "   2. Or run: nvm install $REQUIRED_MAJOR"
            echo "   3. Then try your commit again"
            echo ""
            exit 1
        fi


        echo "   ✅ Node.js version OK"
    else
        echo "   ⚠️  Could not read engines.node field"
        exit 1
    fi
else
    echo "   ⚠️  package.json with no engines field found"
    exit 1
fi

# 2. Check npm version — required for min-release-age (supply-chain cooldown in .npmrc)
echo "2️⃣ Checking npm version..."
CURRENT_NPM=$(npm --version)

NPM_REQUIREMENT=$(node -e "
    try {
        const pkg = require('$ENGINES_FILE');
        if (pkg.engines && pkg.engines.npm) {
            console.log(pkg.engines.npm);
        }
    } catch(e) {
        process.exit(1);
    }
")

if [ -n "$NPM_REQUIREMENT" ]; then
    echo "   📝 Required npm: $NPM_REQUIREMENT"
    echo "   💻 Current npm:  $CURRENT_NPM"

    # Compare current vs required as "major.minor" tuples (we only enforce major.minor)
    CURRENT_NPM_MAJOR=$(echo "$CURRENT_NPM" | sed 's/^\([0-9]*\)\..*/\1/')
    CURRENT_NPM_MINOR=$(echo "$CURRENT_NPM" | sed 's/^[0-9]*\.\([0-9]*\)\..*/\1/')
    REQUIRED_NPM_MAJOR=$(echo "$NPM_REQUIREMENT" | sed 's/[^0-9]*\([0-9]*\).*/\1/')
    REQUIRED_NPM_MINOR=$(echo "$NPM_REQUIREMENT" | sed 's/[^0-9]*[0-9]*\.\([0-9]*\).*/\1/')
    # Default missing minor to 0
    [ -z "$REQUIRED_NPM_MINOR" ] && REQUIRED_NPM_MINOR=0

    NPM_OK=true
    if [ "$CURRENT_NPM_MAJOR" -lt "$REQUIRED_NPM_MAJOR" ]; then
        NPM_OK=false
    elif [ "$CURRENT_NPM_MAJOR" -eq "$REQUIRED_NPM_MAJOR" ] && [ "$CURRENT_NPM_MINOR" -lt "$REQUIRED_NPM_MINOR" ]; then
        NPM_OK=false
    fi

    if [ "$NPM_OK" = "false" ]; then
        echo ""
        echo "❌ npm version too old!"
        echo "   Required: npm >= $REQUIRED_NPM_MAJOR.$REQUIRED_NPM_MINOR (from: $NPM_REQUIREMENT)"
        echo "   Current:  $CURRENT_NPM"
        echo ""
        echo "   .npmrc enables min-release-age (supply-chain cooldown), which requires npm 11.10+."
        echo "   An older npm will silently ignore the cooldown setting."
        echo ""
        echo "   To fix this:"
        echo "   1. Run: npm install -g npm@latest"
        echo "   2. Then try your commit again"
        echo ""
        exit 1
    fi

    echo "   ✅ npm version OK"
else
    echo "   ⚠️  Could not read engines.npm field"
fi

echo ""
echo "✅ All pre-commit checks passed!"
echo ""
