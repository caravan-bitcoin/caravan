registry=https://registry.npmjs.org/

# Reject any package version published less than 7 days ago (value is in days).
# Limits exposure to short-window supply-chain attacks (e.g. compromised
# maintainer credentials). Available in npm >= 11.10.
# To temporarily bypass for a single install: `npm config set min-release-age 0`
# and revert when done. Do not combine with `--before` in the same invocation;
# npm errors out if both are set.
min-release-age=7
